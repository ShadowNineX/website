<canvas
  id="three-bg"
  transition:persist="three-background"
  class="fixed inset-0 -z-10 h-full w-full pointer-events-none"></canvas>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("three-bg") as HTMLCanvasElement;
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  );

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(
    48,
    window.innerWidth / window.innerHeight,
    0.1,
    100,
  );
  camera.position.set(0, 0, 9.5);

  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
    alpha: true,
  });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setClearColor(0xfff7df, 0);

  scene.add(new THREE.AmbientLight(0xfff4cf, 1.45));

  const sun = new THREE.DirectionalLight(0xffffff, 1.4);
  sun.position.set(5, 6, 7);
  scene.add(sun);

  const skyLight = new THREE.PointLight(0x5bb7f0, 1.6, 28);
  skyLight.position.set(-5, 3, 5);
  scene.add(skyLight);

  const honeyLight = new THREE.PointLight(0xffb23f, 1.8, 24);
  honeyLight.position.set(5, -2.4, 4);
  scene.add(honeyLight);

  const world = new THREE.Group();
  scene.add(world);

  const softLine = new THREE.LineBasicMaterial({
    color: 0x4fa8dc,
    transparent: true,
    opacity: 0.18,
  });
  const warmLine = new THREE.LineBasicMaterial({
    color: 0xf3a53f,
    transparent: true,
    opacity: 0.22,
  });

  const createBadgeTexture = () => {
    const size = 512;
    const textureCanvas = document.createElement("canvas");
    textureCanvas.width = size;
    textureCanvas.height = size;

    const context = textureCanvas.getContext("2d");
    if (!context) return null;

    const gradient = context.createLinearGradient(0, 0, size, size);
    gradient.addColorStop(0, "#fff1ad");
    gradient.addColorStop(0.52, "#ffbf58");
    gradient.addColorStop(1, "#65b7e8");
    context.fillStyle = gradient;
    context.fillRect(0, 0, size, size);

    context.fillStyle = "rgba(255, 255, 255, 0.58)";
    context.beginPath();
    context.ellipse(254, 262, 168, 118, -0.56, 0, Math.PI * 2);
    context.fill();
    context.beginPath();
    context.ellipse(300, 272, 168, 118, 0.56, 0, Math.PI * 2);
    context.fill();

    context.strokeStyle = "rgba(126, 75, 23, 0.42)";
    context.lineWidth = 16;
    context.beginPath();
    context.moveTo(122, 322);
    context.quadraticCurveTo(236, 198, 386, 176);
    context.stroke();
    context.beginPath();
    context.moveTo(388, 322);
    context.quadraticCurveTo(280, 200, 126, 176);
    context.stroke();

    context.fillStyle = "#3f2618";
    context.font =
      "700 58px system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif";
    context.textAlign = "center";
    context.textBaseline = "middle";
    context.fillText("ShadowNine", 256, 104);

    const texture = new THREE.CanvasTexture(textureCanvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    texture.anisotropy = 4;
    return texture;
  };

  const badge = new THREE.Mesh(
    new THREE.CylinderGeometry(1.35, 1.35, 0.16, 96),
    [
      new THREE.MeshStandardMaterial({
        color: 0xf7a943,
        roughness: 0.38,
        metalness: 0.08,
      }),
      new THREE.MeshStandardMaterial({
        map: createBadgeTexture(),
        roughness: 0.3,
        metalness: 0.04,
      }),
      new THREE.MeshStandardMaterial({
        map: createBadgeTexture(),
        roughness: 0.3,
        metalness: 0.04,
      }),
    ],
  );
  badge.position.set(3.2, 2.1, -4.2);
  badge.rotation.set(0.28, -0.34, 0.08);
  world.add(badge);

  const floaters: Array<{
    object: THREE.Object3D;
    spin: THREE.Vector3;
    drift: number;
    originY: number;
  }> = [];

  const addFloater = (
    object: THREE.Object3D,
    position: THREE.Vector3,
    scale: number,
    spin: THREE.Vector3,
    drift: number,
  ) => {
    object.position.copy(position);
    object.scale.setScalar(scale);
    world.add(object);
    floaters.push({ object, spin, drift, originY: position.y });
  };

  const materials = {
    honey: new THREE.MeshStandardMaterial({
      color: 0xffb84d,
      roughness: 0.42,
      metalness: 0.1,
      transparent: true,
      opacity: 0.72,
    }),
    sky: new THREE.MeshStandardMaterial({
      color: 0x75c7ef,
      roughness: 0.4,
      metalness: 0.08,
      transparent: true,
      opacity: 0.64,
      wireframe: true,
    }),
    cream: new THREE.MeshStandardMaterial({
      color: 0xfff4d6,
      roughness: 0.55,
      metalness: 0.04,
    }),
  };

  addFloater(
    new THREE.Mesh(new THREE.TorusGeometry(1.12, 0.055, 12, 96), materials.honey),
    new THREE.Vector3(-5.1, 2.2, -5.5),
    1,
    new THREE.Vector3(0.001, 0.0018, 0.0007),
    0.6,
  );
  addFloater(
    new THREE.Mesh(new THREE.IcosahedronGeometry(1.25, 1), materials.sky),
    new THREE.Vector3(5.2, -2.7, -5.8),
    0.86,
    new THREE.Vector3(-0.0014, 0.001, 0.0017),
    0.72,
  );
  addFloater(
    new THREE.Mesh(new THREE.BoxGeometry(1.55, 1.55, 1.55), materials.cream),
    new THREE.Vector3(-2.5, -3.35, -6.3),
    0.6,
    new THREE.Vector3(0.0012, -0.001, 0.0015),
    0.42,
  );

  const rails = new THREE.Group();
  for (let i = 0; i < 8; i++) {
    const y = -4.6 + i * 1.25;
    const curve = new THREE.CatmullRomCurve3([
      new THREE.Vector3(-9, y, -8 - i * 0.34),
      new THREE.Vector3(-3.4, y + Math.sin(i) * 0.72, -9.2),
      new THREE.Vector3(2.1, y - Math.cos(i) * 0.62, -8.5),
      new THREE.Vector3(9, y + Math.sin(i * 1.3) * 0.5, -10.4),
    ]);
    const geometry = new THREE.BufferGeometry().setFromPoints(
      curve.getPoints(90),
    );
    rails.add(new THREE.Line(geometry, i % 2 ? softLine : warmLine));
  }
  scene.add(rails);

  const mouse = new THREE.Vector2(0, 0);

  const onPointerMove = (event: PointerEvent) => {
    mouse.x = (event.clientX / window.innerWidth - 0.5) * 2;
    mouse.y = (event.clientY / window.innerHeight - 0.5) * 2;
  };

  const onResize = () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);
  };

  window.addEventListener("pointermove", onPointerMove, { passive: true });
  window.addEventListener("resize", onResize);
  document.addEventListener("astro:after-swap", onResize);
  document.addEventListener("astro:page-load", onResize);

  const startedAt = performance.now();
  (function animate() {
    requestAnimationFrame(animate);
    const elapsed = (performance.now() - startedAt) / 1000;
    const motionScale = prefersReducedMotion.matches ? 0.22 : 1;

    world.rotation.x +=
      (mouse.y * 0.055 - world.rotation.x) * 0.018 * motionScale;
    world.rotation.y +=
      (mouse.x * 0.08 - world.rotation.y) * 0.018 * motionScale;
    rails.rotation.z = Math.sin(elapsed * 0.08) * 0.025;

    badge.rotation.z = Math.sin(elapsed * 0.42) * 0.05;
    for (const floater of floaters) {
      floater.object.rotation.x += floater.spin.x * motionScale;
      floater.object.rotation.y += floater.spin.y * motionScale;
      floater.object.rotation.z += floater.spin.z * motionScale;
      floater.object.position.y =
        floater.originY + Math.sin(elapsed * floater.drift) * 0.12;
    }

    honeyLight.position.x = Math.sin(elapsed * 0.28) * 4.5;
    skyLight.position.y = 2.5 + Math.cos(elapsed * 0.22) * 1.4;
    renderer.render(scene, camera);
  })();
</script>
