---
import { SEO } from "astro-seo";
import type { Props as SEOProps } from "astro-seo";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  openGraph?: SEOProps["openGraph"];
  twitter?: SEOProps["twitter"];
  noindex?: boolean;
  nofollow?: boolean;
}

const { title, description, canonical, openGraph, twitter, noindex, nofollow } =
  Astro.props;

const siteName = "ShadowNine";
const defaultTitle = "ShadowNine";
const resolvedTitle = title ?? defaultTitle;
const resolvedDescription =
  description ??
  "ShadowNine's personal website for weird projects, experiments, links, and notes.";
const canonicalUrl =
  canonical ??
  new URL(Astro.url.pathname + Astro.url.search, Astro.site ?? Astro.url).href;
const socialImage = "https://github.com/ShadowNineX.png?size=512";
const socialImageAlt = "ShadowNine GitHub avatar";
const shouldTemplateTitle = Boolean(title && title !== siteName);

const resolvedOpenGraph =
  openGraph ??
  ({
    basic: {
      title: resolvedTitle,
      type: "website",
      image: socialImage,
      url: canonicalUrl,
    },
    optional: {
      description: resolvedDescription,
      siteName,
      locale: "en_US",
    },
    image: {
      alt: socialImageAlt,
    },
  } satisfies SEOProps["openGraph"]);

const resolvedTwitter =
  twitter ??
  ({
    card: "summary",
    title: resolvedTitle,
    description: resolvedDescription,
    image: socialImage,
    imageAlt: socialImageAlt,
  } satisfies SEOProps["twitter"]);
---

<head>
  <script is:inline>
    (function () {
      const mq = window.matchMedia("(prefers-color-scheme: dark)");
      document.documentElement.classList.toggle("dark", mq.matches);
      mq.addEventListener("change", (e) =>
        document.documentElement.classList.toggle("dark", e.matches),
      );
      document.addEventListener("astro:before-swap", (e) => {
        e.newDocument.documentElement.classList.toggle(
          "dark",
          document.documentElement.classList.contains("dark"),
        );
      });
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="theme-color" content="#ff0000" />
  <meta name="generator" content={Astro.generator} />
  <SEO
    title={resolvedTitle}
    titleTemplate={shouldTemplateTitle ? `%s | ${siteName}` : undefined}
    description={resolvedDescription}
    canonical={canonicalUrl}
    openGraph={resolvedOpenGraph}
    twitter={resolvedTwitter}
    {noindex}
    {nofollow}
    extend={{
      link: [
        { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
        { rel: "icon", href: "/favicon.ico" },
      ],
    }}
  />
  <slot />
</head>
