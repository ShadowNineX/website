---
import { SEO } from "astro-seo";
import { canonicalUrlForPath } from "@/lib/routes";
import type { Props as SEOProps } from "astro-seo";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  openGraph?: SEOProps["openGraph"];
  twitter?: SEOProps["twitter"];
  noindex?: boolean;
  nofollow?: boolean;
  themeColor?: string;
}

const {
  title,
  description,
  canonical,
  openGraph,
  twitter,
  noindex,
  nofollow,
  themeColor = "#ff0000",
} = Astro.props;

const siteName = "ShadowNine";
const defaultTitle = "ShadowNine";
const resolvedTitle = title ?? defaultTitle;
const resolvedDescription =
  description ??
  "ShadowNine's personal website for weird projects, experiments, links, and notes.";
const canonicalBaseUrl = Astro.site ?? Astro.url;
const canonicalUrl =
  canonical ?? canonicalUrlForPath(Astro.url.pathname, canonicalBaseUrl);
const socialImage = "https://github.com/ShadowNineX.png?size=512";
const socialImageAlt = "ShadowNine GitHub avatar";
const socialImageType = "image/png";
const socialImageWidth = 512;
const socialImageHeight = 512;
const twitterCreator = "@ShadowNineX";
const twitterSite = "@ShadowNineX";
const shouldTemplateTitle = Boolean(title && title !== siteName);

const resolvedOpenGraph =
  openGraph ??
  ({
    basic: {
      title: resolvedTitle,
      type: "website",
      image: socialImage,
      url: canonicalUrl,
    },
    optional: {
      description: resolvedDescription,
      siteName,
      locale: "en_US",
    },
    image: {
      secureUrl: socialImage,
      type: socialImageType,
      width: socialImageWidth,
      height: socialImageHeight,
      alt: socialImageAlt,
    },
  } satisfies SEOProps["openGraph"]);

const defaultTwitter = {
  card: "summary",
  site: twitterSite,
  creator: twitterCreator,
  title: resolvedTitle,
  description: resolvedDescription,
  image: socialImage,
  imageAlt: socialImageAlt,
} satisfies SEOProps["twitter"];
const resolvedTwitter = {
  ...defaultTwitter,
  ...twitter,
  site: twitter?.site ?? defaultTwitter.site,
  creator: twitter?.creator ?? defaultTwitter.creator,
} satisfies SEOProps["twitter"];
---

<head>
  <script is:inline>
    (function () {
      const mq = window.matchMedia("(prefers-color-scheme: dark)");
      document.documentElement.classList.toggle("dark", mq.matches);
      mq.addEventListener("change", (e) =>
        document.documentElement.classList.toggle("dark", e.matches),
      );
      document.addEventListener("astro:before-swap", (e) => {
        e.newDocument.documentElement.classList.toggle(
          "dark",
          document.documentElement.classList.contains("dark"),
        );
      });
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="theme-color" content={themeColor} />
  <meta name="generator" content={Astro.generator} />
  <SEO
    title={resolvedTitle}
    titleTemplate={shouldTemplateTitle ? `%s | ${siteName}` : undefined}
    description={resolvedDescription}
    canonical={canonicalUrl}
    openGraph={resolvedOpenGraph}
    twitter={resolvedTwitter}
    {noindex}
    {nofollow}
    extend={{
      link: [
        { rel: "icon", type: "image/png", href: "/favicon.png" },
      ],
    }}
  />
  <slot />
</head>
