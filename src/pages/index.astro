---
import { Image } from "astro:assets";
import { Icon } from "astro-iconify";
import avatar from "@/content/blog/hello-world.jpg";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const githubUsername = "ShadowNineX";
const githubProfileUrl = `https://github.com/${githubUsername}`;
const blogPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latestBlogPost = blogPosts[0];

interface GitHubUser {
  login: string;
  name: string | null;
  bio: string | null;
  blog: string | null;
  public_repos: number;
  followers: number;
  following: number;
  created_at: string;
}

interface GitHubRepo {
  name: string;
  description: string | null;
  html_url: string;
  homepage: string | null;
  language: string | null;
  topics: string[];
  stargazers_count: number;
  pushed_at: string;
  license: {
    spdx_id: string | null;
  } | null;
}

const fetchGitHubJson = async <T,>(url: string): Promise<T> => {
  const token = import.meta.env.GITHUB_TOKEN as string | undefined;
  const response = await fetch(url, {
    headers: {
      Accept: "application/vnd.github+json",
      "X-GitHub-Api-Version": "2022-11-28",
      ...(token ? { Authorization: `Bearer ${token}` } : {}),
    },
  });

  if (!response.ok) {
    throw new Error(
      `GitHub API request failed: ${response.status} ${response.statusText} for ${url}`,
    );
  }

  return (await response.json()) as T;
};

const [githubUser, githubRepos] = await Promise.all([
  fetchGitHubJson<GitHubUser>(`https://api.github.com/users/${githubUsername}`),
  fetchGitHubJson<GitHubRepo[]>(
    `https://api.github.com/users/${githubUsername}/repos?sort=updated&per_page=100`,
  ),
]);

const formatMonthYear = (date: string) =>
  new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
  }).format(new Date(date));
const formatBlogDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(date);

const totalStars = githubRepos.reduce(
  (sum, repo) => sum + repo.stargazers_count,
  0,
);
const displayName = githubUser.name ?? githubUser.login;
const profileBio = githubUser.bio ?? "Developer, builder, tinkerer.";

const profileStats = [
  {
    label: "Public repos",
    value: githubUser.public_repos.toString(),
    icon: "lucide:folder-git-2",
    tileClass:
      "border-sky-300/35 bg-sky-300/10 shadow-sky-300/10 hover:border-sky-300/55",
    iconClass: "text-sky-500 dark:text-sky-300",
  },
  {
    label: "GitHub stars",
    value: totalStars.toString(),
    icon: "lucide:star",
    tileClass:
      "border-amber-300/40 bg-amber-300/15 shadow-amber-300/10 hover:border-amber-300/60",
    iconClass: "text-amber-600 dark:text-amber-300",
  },
  {
    label: "Since",
    value: formatMonthYear(githubUser.created_at),
    icon: "lucide:calendar-days",
    tileClass:
      "border-rose-300/35 bg-rose-300/10 shadow-rose-300/10 hover:border-rose-300/55",
    iconClass: "text-rose-500 dark:text-rose-300",
  },
];

const focusAreas = [
  {
    title: "AI-assisted tools",
    description:
      "Building MCP-powered tools that make developer workflows, game tooling, and reverse-engineering projects easier to steer.",
    icon: "lucide:bot",
  },
  {
    title: "Game and modding work",
    description:
      "Exploring Unreal Engine, Portal 2: Community Edition, Cheat Engine, Neodash, Rising World, and the toolchains behind playable ideas.",
    icon: "lucide:gamepad-2",
  },
  {
    title: "Personal web experiments",
    description:
      "Making Astro/Vue sites, editor experiments, and TypeScript projects because the idea sounds cozy, useful, or weird enough to try.",
    icon: "lucide:sparkles",
  },
];

const tailsCompanionCards = [
  {
    title: "A steady second set of hands",
    description:
      "Tails is the helper I want nearby when a project has too many tabs open: calm, practical, and ready to hold the thread while I figure out the next step.",
    icon: "lucide:hand-heart",
    tileClass: "border-amber-300/45 bg-amber-200/20 shadow-amber-300/10",
  },
  {
    title: "Tools that feel like home",
    description:
      "The best workspace tools should feel warm enough to return to, with little comforts that make coding, notes, and experiments feel less lonely.",
    icon: "lucide:home",
    tileClass: "border-sky-300/40 bg-sky-200/20 shadow-sky-300/10",
  },
  {
    title: "Trust before speed",
    description:
      "Helpful automation matters most when it is clear, patient, and easy to trust. Tails fits that mood: useful without trying to take the whole room over.",
    icon: "lucide:shield-check",
    tileClass: "border-rose-300/40 bg-rose-200/20 shadow-rose-300/10",
  },
];

const projectIcons: Record<string, string> = {
  "ce-mcp": "lucide:cpu",
  CESDK: "lucide:plug",
  headbreaker: "lucide:puzzle",
  "vscode-eta": "lucide:braces",
  "p2ce-hono-web-server": "lucide:server",
  "wallpaper-engine": "lucide:monitor-play",
  "MCP-UAsset-Toolkit": "lucide:wrench",
  ToSteamArtwork: "lucide:image",
};

const projectMeta: Record<string, string> = {
  "p2ce-hono-web-server": "Portal 2 CE",
  "wallpaper-engine": "npm package",
  "MCP-UAsset-Toolkit": "Unreal Engine",
  ToSteamArtwork: "Steam tools",
};

const projectDescription: Record<string, string> = {
  "ce-mcp":
    "A C# MCP bridge for automating Cheat Engine with AI. It is the most-starred public project on the profile.",
  "MCP-UAsset-Toolkit":
    "Automation for Unreal Engine reverse engineering using UAsset API, CUE4Parse, MCP, and AI-assisted workflows.",
  ToSteamArtwork:
    "A TypeScript utility that converts images, GIFs, and videos to Steam artwork dimensions.",
};

const projects = githubRepos
  .filter((repo) => repo.description)
  .sort((a, b) => {
    const stars = b.stargazers_count - a.stargazers_count;
    if (stars !== 0) return stars;

    return new Date(b.pushed_at).getTime() - new Date(a.pushed_at).getTime();
  })
  .slice(0, 6)
  .map((repo) => {
    const meta =
      projectMeta[repo.name] ??
      (repo.stargazers_count === 1
        ? "1 star"
        : `${repo.stargazers_count} stars`);

    return {
      name: repo.name,
      description:
        projectDescription[repo.name] ??
        repo.description ??
        "A public GitHub project from ShadowNine.",
      href: repo.html_url,
      language: repo.language ?? "Code",
      meta,
      icon: projectIcons[repo.name] ?? "lucide:folder-git-2",
    };
  });

const stackGroups = [
  {
    title: "Languages",
    items: [
      { label: "TypeScript", icon: "simple-icons:typescript", color: "#3178C6" },
      { label: "C#", icon: "simple-icons:csharp", color: "#512BD4" },
      { label: "C++", icon: "simple-icons:cplusplus", color: "#00599C" },
      { label: "Kotlin", icon: "simple-icons:kotlin", color: "#7F52FF" },
      { label: "Go", icon: "simple-icons:go", color: "#00ADD8" },
      { label: "Lua", icon: "simple-icons:lua", color: "#2C2D72" },
      { label: "Python", icon: "simple-icons:python", color: "#3776AB" },
    ],
  },
  {
    title: "Frontend",
    items: [
      { label: "Astro", icon: "simple-icons:astro", color: "#FF5D01" },
      { label: "Vue", icon: "simple-icons:vuedotjs", color: "#4FC08D" },
      { label: "Tailwind CSS", icon: "simple-icons:tailwindcss", color: "#06B6D4" },
      { label: "shadcn-vue", icon: "lucide:layers-3", color: "#71717A" },
      { label: "Vite", icon: "simple-icons:vite", color: "#646CFF" },
    ],
  },
  {
    title: "Tools",
    items: [
      { label: "Bun", icon: "simple-icons:bun", color: "#000000", darkColor: "#FBF0DF" },
      { label: ".NET", icon: "simple-icons:dotnet", color: "#512BD4" },
      { label: "CMake", icon: "simple-icons:cmake", color: "#064F8C" },
      { label: "Unreal Engine", icon: "simple-icons:unrealengine", color: "#0E1128", darkColor: "#F5F7FA" },
      { label: "MCP", icon: "lucide:bot", color: "#22D3EE" },
    ],
  },
];

const links = [
  {
    label: "GitHub",
    href: githubProfileUrl,
    icon: "simple-icons:github",
  },
  {
    label: "Links",
    href: `${base}/linktree`,
    icon: "lucide:link",
  },
  {
    label: "Blog",
    href: `${base}/blog`,
    icon: "lucide:book-open",
  },
];

const musicWidgets = [
  {
    label: "Spotify",
    href: "https://open.spotify.com/user/31wl2m3aqxcky555yhqi7epzau7u",
    icon: "simple-icons:spotify",
    color: "#1DB954",
    src: "https://spotify-github-profile.kittinanx.com/api/view?uid=31wl2m3aqxcky555yhqi7epzau7u&cover_image=true&theme=default&show_offline=false&background_color=121212&interchange=false&profanity=false&bar_color=3d8b37",
    alt: "Spotify now playing",
  },
  {
    label: "Last.fm",
    href: "https://www.last.fm/user/ShadowNineX",
    icon: "simple-icons:lastdotfm",
    color: "#D51007",
    src: "https://lastfm-recently-played.vercel.app/api?user=ShadowNineX&header_style=normal_stats&footer_style=wave&maxage=60&loved=true",
    alt: "Last.fm recently played",
  },
];
---

<Layout
  title={displayName}
  description={`${displayName}'s cozy personal site for projects, tools, links, and notes.`}
>
  <section
    class="mx-auto grid max-w-5xl gap-10 px-6 py-12 md:grid-cols-[1.05fr_0.95fr] md:items-center md:py-20"
  >
    <div>
      <p
        class="inline-flex items-center gap-2 rounded-md border border-primary/25 bg-primary/10 px-3 py-1.5 text-sm font-medium text-primary"
      >
        <Icon name="lucide:terminal" width="15" height="15" />
        cozy project workshop
      </p>
      <h1
        class="mt-5 text-4xl font-bold tracking-tight text-balance sm:text-6xl"
      >
        ShadowNine's warm little workshop for code, games, and ideas.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-muted-foreground">
        I'm {displayName}, a developer who likes building tools, modding
        experiments, cozy web pages, and odd ideas that need a place to live.
        I keep the projects here close to the stuff I care about: practical
        tools, playful experiments, game systems, music, and small notes from
        whatever I am building next.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        {
          links.map((link) => (
            <a
              href={link.href}
            class="inline-flex items-center gap-2 rounded-md border border-border bg-card/90 px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent"
            >
              <Icon name={link.icon} width="16" height="16" />
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="relative">
      <div
        class="absolute inset-0 rounded-lg border border-primary/15 bg-card/35"
      >
      </div>
      <div class="group/card h-170 perspective-[1400px] sm:h-180">
        <div
          class="relative h-full rounded-lg animate-profile-card-spin transform-3d group-hover/card:paused group-focus-within/card:paused motion-reduce:animate-none"
        >
          <div
            class="absolute left-0 top-0 h-full w-3 origin-left bg-primary/30 shadow-lg shadow-primary/20 transform-[translateZ(6px)_rotateY(90deg)]"
          >
          </div>
          <div
            class="absolute right-0 top-0 h-full w-3 origin-right bg-amber-300/25 shadow-lg shadow-amber-300/10 transform-[translateZ(6px)_rotateY(-90deg)]"
          >
          </div>
          <div
            class="absolute left-0 top-0 h-3 w-full origin-top bg-cyan-300/25 transform-[translateZ(6px)_rotateX(-90deg)]"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 h-3 w-full origin-bottom bg-primary/20 transform-[translateZ(6px)_rotateX(90deg)]"
          >
          </div>
          <div
            class="absolute inset-0 overflow-hidden border border-primary/25 bg-card shadow-2xl shadow-primary/20 backface-hidden transform-[translateZ(6px)]"
          >
            <div class="absolute inset-x-0 top-0 h-1 bg-linear-to-r from-sky-300 via-primary to-rose-300"></div>
            <Image
              src={avatar}
              alt="ShadowNine avatar"
              width={512}
              height={512}
              loading="eager"
              class="h-107.5 w-full object-cover sm:h-117.5"
            />
            <div class="relative border-t border-border p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-primary">
                    GitHub profile
                  </p>
                  <h2 class="mt-1 text-2xl font-bold tracking-tight">
                    <span class="bg-linear-to-r from-amber-500 via-rose-400 to-sky-500 bg-clip-text text-transparent dark:from-amber-200 dark:via-orange-100 dark:to-sky-200">
                      {displayName}
                    </span>
                  </h2>
                  <p class="mt-2 inline-flex items-center gap-2 rounded-md border border-amber-300/35 bg-amber-300/15 px-2.5 py-1 text-sm text-muted-foreground">
                    <Icon
                      name="lucide:sparkle"
                      width="14"
                      height="14"
                      class="text-amber-500 dark:text-amber-300"
                    />
                    {profileBio}
                  </p>
                </div>
              </div>
              <dl class="mt-5 grid grid-cols-3 gap-3">
                {
                  profileStats.map((stat) => (
                    <div
                      class:list={[
                        "rounded-md border bg-background/75 p-3 shadow-lg backdrop-blur transition-colors",
                        stat.tileClass,
                      ]}
                    >
                      <dt class="flex items-center justify-center gap-1.5 text-[11px] text-muted-foreground">
                        <Icon
                          name={stat.icon}
                          width="13"
                          height="13"
                          class={stat.iconClass}
                        />
                        {stat.label}
                      </dt>
                      <dd class="mt-2 text-center text-lg font-bold text-foreground">
                        {stat.value}
                      </dd>
                    </div>
                  ))
                }
              </dl>
            </div>
          </div>

          <div
            class="isolate absolute inset-0 overflow-hidden border border-border bg-card shadow-2xl shadow-primary/20 backface-hidden transform-[rotateY(180deg)_translateZ(6px)]"
          >
            <div class="absolute inset-0 -z-10 bg-card"></div>

            <div class="relative flex h-full flex-col p-4">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-primary">
                    cozy listening corner
                  </p>
                  <h2 class="mt-1 text-2xl font-bold tracking-tight">
                    Music and comfort tracks
                  </h2>
                </div>
                <Icon
                  name="lucide:music-4"
                  width="24"
                  height="24"
                  class="text-primary"
                />
              </div>

              <div class="music-scroll mt-4 min-h-0 flex-1 overflow-y-auto overscroll-contain rounded-lg border border-border bg-background/70 p-3">
                <div class="space-y-3">
                {
                  musicWidgets.map((widget) => (
                    <a
                      href={widget.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group/music overflow-hidden rounded-lg bg-background/90 shadow-lg shadow-black/10 backdrop-blur transition-transform hover:-translate-y-0.5"
                      style={`--music-color: ${widget.color};`}
                    >
                      <div class="flex items-center justify-between px-4 py-2.5">
                        <span class="flex items-center gap-2 text-sm font-semibold">
                          <span class="flex size-8 items-center justify-center rounded-md bg-card text-(--music-color)">
                            <Icon name={widget.icon} width="17" height="17" />
                          </span>
                          {widget.label}
                        </span>
                        <Icon
                          name="lucide:arrow-up-right"
                          width="15"
                          height="15"
                          class="text-muted-foreground transition-transform group-hover/music:-translate-y-0.5 group-hover/music:translate-x-0.5"
                        />
                      </div>
                      <img
                        src={widget.src}
                        alt={widget.alt}
                        loading="lazy"
                        class="block h-auto w-full border-t border-border/50 bg-background"
                      />
                    </a>
                  ))
                }
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-border bg-card/55">
    <div class="mx-auto grid max-w-5xl gap-4 px-6 py-8 md:grid-cols-3">
      {
        focusAreas.map((area) => (
          <article class="rounded-lg border border-border bg-background/75 p-5 shadow-sm">
            <Icon
              name={area.icon}
              width="22"
              height="22"
              class="text-primary"
            />
            <h2 class="mt-4 text-base font-semibold tracking-tight">
              {area.title}
            </h2>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {area.description}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-14">
    <div class="overflow-hidden rounded-lg border border-amber-300/35 bg-card/85 shadow-xl shadow-amber-300/10 backdrop-blur-xl">
      <div class="grid gap-0 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="border-b border-border bg-background/70 p-6 sm:p-8 lg:border-b-0 lg:border-r">
          <p class="inline-flex items-center gap-2 rounded-md border border-amber-300/35 bg-amber-200/20 px-3 py-1.5 text-sm font-medium text-primary">
            <Icon name="lucide:heart-handshake" width="15" height="15" />
            Tails in the workshop
          </p>
          <h2 class="mt-5 text-3xl font-bold tracking-tight text-balance sm:text-4xl">
            A trusted helper for the soft parts of building.
          </h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">
            I like tools that make the room feel kinder. Tails is that kind of
            presence for this site: a friendly workshop companion for sorting
            ideas, keeping momentum, and making the desk feel a little more
            like home.
          </p>
          <a
            href={`${base}/blog/tails-trust-tools-home`}
            class="mt-6 inline-flex items-center gap-2 rounded-md border border-border bg-background/80 px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent"
          >
            <Icon name="lucide:book-heart" width="16" height="16" />
            Read the note
          </a>
        </div>

        <div class="grid gap-3 bg-linear-to-br from-amber-200/20 via-sky-200/15 to-rose-200/20 p-4 sm:p-6">
          {
            tailsCompanionCards.map((card) => (
              <article
                class:list={[
                  "rounded-md border p-4 shadow-sm backdrop-blur transition-transform hover:-translate-y-0.5",
                  card.tileClass,
                ]}
              >
                <div class="flex items-start gap-3">
                  <span class="flex size-10 shrink-0 items-center justify-center rounded-md bg-background/75 text-primary shadow-sm">
                    <Icon name={card.icon} width="19" height="19" />
                  </span>
                  <div>
                    <h3 class="font-semibold tracking-tight">{card.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-muted-foreground">
                      {card.description}
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {
    latestBlogPost && (
      <section class="mx-auto max-w-5xl px-6 py-14">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-medium text-primary">Latest note</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight">
              Fresh from the workbench
            </h2>
          </div>
          <a
            href={`${base}/blog`}
            class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
          >
            View all notes
            <Icon name="lucide:arrow-up-right" width="15" height="15" />
          </a>
        </div>

        <a
          href={`${base}/blog/${latestBlogPost.id}`}
          class:list={[
            "group mt-8 grid overflow-hidden rounded-lg border border-border bg-card shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/45 hover:shadow-xl hover:shadow-primary/10",
            latestBlogPost.data.image && "md:grid-cols-[0.95fr_1.05fr]",
          ]}
        >
          {latestBlogPost.data.image && (
            <div class="overflow-hidden border-b border-border bg-muted md:border-b-0 md:border-r">
              <Image
                src={latestBlogPost.data.image}
                alt={latestBlogPost.data.imageAlt ?? ""}
                width={1200}
                height={630}
                transition:name={`blog-image-${latestBlogPost.id}`}
                transition:animate="initial"
                class="aspect-video h-full w-full object-cover"
              />
            </div>
          )}
          <div class="flex flex-col justify-center p-5 sm:p-6">
            <div class="flex flex-wrap items-center gap-3 text-xs font-medium uppercase tracking-wide text-muted-foreground">
              <time
                transition:name={`blog-date-${latestBlogPost.id}`}
                transition:animate="initial"
              >
                {formatBlogDate(latestBlogPost.data.date)}
              </time>
              <span class="h-1 w-1 rounded-full bg-primary/70"></span>
              <span>Fresh note</span>
            </div>
            <h3
              transition:name={`blog-title-${latestBlogPost.id}`}
              transition:animate="initial"
              class="mt-3 text-2xl font-bold tracking-tight transition-colors group-hover:text-primary sm:text-3xl"
            >
              {latestBlogPost.data.title}
            </h3>
            <p
              transition:name={`blog-description-${latestBlogPost.id}`}
              transition:animate="initial"
              class="mt-3 text-sm leading-6 text-muted-foreground sm:text-base"
            >
              {latestBlogPost.data.description}
            </p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-primary">
              Read post
              <Icon
                name="lucide:arrow-up-right"
                width="15"
                height="15"
                class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
              />
            </span>
          </div>
        </a>
      </section>
    )
  }

  <section class="mx-auto max-w-5xl px-6 py-14">
    <div
      class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
    >
      <div>
        <p class="text-sm font-medium text-primary">Selected projects</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight">
          Useful things I have built
        </h2>
      </div>
      <a
        href={`${githubProfileUrl}?tab=repositories`}
        class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
      >
        View all repositories
        <Icon name="lucide:arrow-up-right" width="15" height="15" />
      </a>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {
        projects.map((project) => (
          <a
            href={project.href}
            class="group rounded-lg border border-border bg-card p-5 transition-all hover:-translate-y-0.5 hover:border-primary/50 hover:shadow-lg"
          >
            <div class="flex items-start justify-between gap-4">
              <div class="flex items-center gap-3">
                <span class="inline-flex size-10 items-center justify-center rounded-md bg-primary/10 text-primary">
                  <Icon name={project.icon} width="20" height="20" />
                </span>
                <div>
                  <h3 class="font-semibold tracking-tight">{project.name}</h3>
                  <p class="mt-0.5 text-xs text-muted-foreground">
                    {project.language} / {project.meta}
                  </p>
                </div>
              </div>
              <Icon
                name="lucide:arrow-up-right"
                width="16"
                height="16"
                class="text-muted-foreground transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-foreground"
              />
            </div>
            <p class="mt-4 text-sm leading-6 text-muted-foreground">
              {project.description}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-20">
    <div class="grid gap-4 md:grid-cols-[0.85fr_1.15fr]">
      <div class="rounded-lg border border-border bg-card p-6">
        <p class="text-sm font-medium text-primary">Now-ish</p>
        <h2 class="mt-2 text-2xl font-bold tracking-tight">Current pattern</h2>
        <p class="mt-4 text-sm leading-6 text-muted-foreground">
          Most of my recent repos are experiments: AI bots, VS Code language
          tooling, web wallpaper infrastructure, MCP automation, and game
          modding projects. The common thread is simple: follow the idea, make
          it useful, then keep the parts that feel worth returning to.
        </p>
      </div>

      <div class="rounded-lg border border-border bg-card p-6">
        <p class="text-sm font-medium text-primary">Tech stack</p>
        <div class="mt-5 grid gap-5 sm:grid-cols-3">
          {
            stackGroups.map((group) => (
              <div>
                <h3 class="text-sm font-semibold">{group.title}</h3>
                <ul class="mt-3 space-y-2">
                  {group.items.map((item) => (
                    <li class="flex items-center gap-2 text-sm text-muted-foreground">
                      <span
                        class="tech-icon flex size-6 shrink-0 items-center justify-center rounded-md border border-border bg-background/70"
                        style={`--tech-color: ${item.color}; --tech-dark-color: ${item.darkColor ?? item.color};`}
                      >
                        <Icon name={item.icon} width="14" height="14" />
                      </span>
                      {item.label}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .tech-icon {
    color: var(--tech-color);
    box-shadow: inset 0 0 0 1px
      color-mix(in oklch, var(--tech-color) 18%, transparent);
  }

  :global(.dark) .tech-icon {
    color: var(--tech-dark-color);
    box-shadow: inset 0 0 0 1px
      color-mix(in oklch, var(--tech-dark-color) 18%, transparent);
  }
</style>
