---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-iconify";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="Home" description="Welcome to my personal site.">
  <section class="max-w-3xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold tracking-tight">Hey, I'm ShadowNine</h1>
    <p class="mt-4 text-lg text-muted-foreground">
      Developer, builder, tinkerer. Welcome to my corner of the web.
    </p>
    <p
      class="mt-3 inline-flex items-center gap-2 text-sm text-amber-400/90 bg-amber-400/10 border border-amber-400/20 rounded-md px-3 py-1.5"
    >
      <Icon name="lucide:triangle-alert" width="14" height="14" />
      This page is a work in progress — more coming soon.
    </p>
    <div class="mt-8 flex gap-4">
      <a
        href={`${base}/blog`}
        class="inline-flex items-center px-4 py-2 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:opacity-90 transition-opacity"
      >
        Read the blog
      </a>
      <a
        href={`${base}/linktree`}
        class="inline-flex items-center px-4 py-2 rounded-md border border-border text-sm font-medium hover:bg-accent transition-colors"
      >
        Find me online
      </a>
    </div>
  </section>
</Layout>
