---
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Icon } from "astro-iconify";
import { Image } from "astro:assets";
import { getSeoImage } from "@/lib/seo-image";
import { canonicalUrlForPath } from "@/lib/routes";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonicalUrl = canonicalUrlForPath(
  Astro.url.pathname,
  Astro.site ?? Astro.url,
);
const postImage = post.data.image;
const imageAlt = post.data.imageAlt ?? post.data.title;
const ogImage = await getSeoImage({
  image: postImage,
  requestUrl: Astro.url,
  site: Astro.site,
  width: 1200,
  height: 630,
});
const ogImageUrl = ogImage?.url;
const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const imageTransitionName = `blog-image-${post.id}`;
const titleTransitionName = `blog-title-${post.id}`;
const dateTransitionName = `blog-date-${post.id}`;
const descriptionTransitionName = `blog-description-${post.id}`;
---

<Layout
  title={post.data.title}
  description={post.data.description}
  canonical={canonicalUrl}
  openGraph={{
    basic: {
      title: post.data.title,
      type: "article",
      image: ogImageUrl,
      url: canonicalUrl,
    },
    optional: {
      description: post.data.description,
      siteName: "ShadowNine",
      locale: "en_US",
    },
    ...(ogImageUrl && {
      image: {
        secureUrl: ogImageUrl,
        type: ogImage.type,
        width: ogImage.width,
        height: ogImage.height,
        alt: imageAlt,
      },
    }),
    article: {
      publishedTime: post.data.date.toISOString(),
      authors: [post.data.author],
    },
  }}
  twitter={ogImageUrl
    ? {
        card: "summary_large_image",
        title: post.data.title,
        description: post.data.description,
        image: ogImageUrl,
        imageAlt,
      }
    : undefined}
>
  <article class="mx-auto max-w-5xl px-6 py-12 sm:py-16">
    <a
      href={`${base}/blog`}
      class="inline-flex items-center gap-2 rounded-md border border-border bg-card px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
    >
      <Icon name="lucide:arrow-left" width="15" height="15" />
      Back to notes
    </a>

    <header class="mt-8 grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div>
        <div class="flex flex-wrap items-center gap-3 text-xs font-medium uppercase tracking-wide text-muted-foreground">
          <time
            transition:name={dateTransitionName}
            transition:animate="initial"
          >
            {formattedDate}
          </time>
          <span class="h-1 w-1 rounded-full bg-primary/70"></span>
          <span class="normal-case">@{post.data.author}</span>
          <span class="h-1 w-1 rounded-full bg-primary/70"></span>
          <span>Workbench note</span>
        </div>
        <h1
          transition:name={titleTransitionName}
          transition:animate="initial"
          class="mt-4 text-4xl font-bold tracking-tight text-balance sm:text-5xl"
        >
          {post.data.title}
        </h1>
        <p
          transition:name={descriptionTransitionName}
          transition:animate="initial"
          class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground sm:text-lg"
        >
          {post.data.description}
        </p>
      </div>

      {
        postImage && (
          <Image
            src={postImage}
            alt={post.data.imageAlt ?? ""}
            width={1200}
            height={630}
            loading="eager"
            transition:name={imageTransitionName}
            transition:animate="initial"
            class="aspect-video w-full rounded-md border border-border object-cover shadow-xl shadow-primary/10"
          />
        )
      }
    </header>

    <div class="mt-12 grid gap-10 lg:grid-cols-[13rem_1fr]">
      <aside class="hidden lg:block">
        <div class="sticky top-28 rounded-md border border-border bg-card/85 p-4 shadow-lg shadow-background/20 backdrop-blur-xl">
          <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">
            Published
          </p>
          <time class="mt-2 block text-sm font-medium">{formattedDate}</time>
          <p class="mt-5 text-xs font-medium uppercase tracking-wide text-muted-foreground">
            Author
          </p>
          <p class="mt-2 text-sm font-medium">@{post.data.author}</p>
          <a
            href={`${base}/blog`}
            class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-foreground"
          >
            <Icon name="lucide:library" width="15" height="15" />
            All notes
          </a>
        </div>
      </aside>

      <div class="rounded-md border border-border bg-card/90 p-5 shadow-xl shadow-background/25 backdrop-blur-xl sm:p-7">
        <div class="blog-prose prose prose-neutral dark:prose-invert max-w-none prose-headings:tracking-tight prose-a:text-primary prose-a:no-underline prose-img:rounded-md prose-p:text-foreground/85 dark:prose-p:text-foreground/88 prose-li:text-foreground/85 dark:prose-li:text-foreground/88">
          <Content />
        </div>

        <footer class="mt-14 border-t border-border pt-6">
          <a
            href={`${base}/blog`}
            class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
          >
            <Icon name="lucide:arrow-left" width="15" height="15" />
            Back to notes
          </a>
        </footer>
      </div>
    </div>
  </article>
</Layout>

<style>
  .blog-prose :global(a) {
    transition: color 150ms ease;
  }

  .blog-prose :global(a:hover) {
    color: var(--foreground);
  }
</style>
