---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-iconify";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="Blog" description="Thoughts, projects, and more.">
  <section class="max-w-3xl mx-auto px-6 py-20">
    <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
    <p class="mt-2 text-muted-foreground">Thoughts, projects, and more.</p>

    <div class="mt-12">
      {
        posts.length === 0 ? (
          <p class="text-muted-foreground">No posts yet — check back soon.</p>
        ) : (
          <ul class="space-y-6">
            {posts.map((post) => (
              <li>
                <a
                  href={`${base}/blog/${post.id}`}
                  class="group relative block rounded-xl overflow-hidden border border-cyan-500/20 bg-card hover:border-cyan-400/60 hover:shadow-[0_0_24px_0_oklch(0.66_0.16_195/_0.18)] transition-all duration-300"
                >
                  {/* teal top accent bar */}
                  <span class="absolute top-0 inset-x-0 h-0.5 bg-linear-to-r from-transparent via-cyan-400/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20" />

                  {post.data.image && (
                    <Image
                      src={post.data.image}
                      alt={post.data.imageAlt ?? ""}
                      width={768}
                      height={240}
                      class="w-full aspect-video object-cover"
                    />
                  )}

                  {/* heavy gradient scrim over bottom half */}
                  <div class="absolute inset-0 bg-linear-to-t from-black/85 via-black/40 to-transparent" />

                  <div class="absolute inset-0 flex flex-col justify-end p-5 z-10">
                    <time class="inline-flex items-center gap-1.5 text-xs font-medium text-cyan-300/90 tracking-wide uppercase">
                      {post.data.date.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </time>
                    <h2 class="mt-1 text-lg font-semibold leading-snug text-white group-hover:text-cyan-200 transition-colors duration-200">
                      {post.data.title}
                    </h2>
                    <p class="mt-1 text-white/70 text-sm leading-relaxed">
                      {post.data.description}
                    </p>
                    <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-cyan-300/80 group-hover:text-cyan-200 transition-colors duration-200">
                      Read more
                      <Icon
                        name="lucide:arrow-right"
                        width="12"
                        height="12"
                        class="transition-transform duration-200 group-hover:translate-x-0.5"
                      />
                    </span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Layout>
