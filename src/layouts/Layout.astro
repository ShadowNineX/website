---
import "../styles/global.css";
import Head from "../components/Head.astro";
import { ClientRouter } from "astro:transitions";
import { Icon } from "astro-iconify";
import CustomCursor from "../components/CustomCursor.astro";
import Footer from "@/components/Footer.astro";
import ThreeBackground from "../components/ThreeBackground.astro";
import { normalizeRoutePath } from "@/lib/routes";
import type { Props as SEOProps } from "astro-seo";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  openGraph?: SEOProps["openGraph"];
  twitter?: SEOProps["twitter"];
  noindex?: boolean;
  nofollow?: boolean;
  themeColor?: string;
  showChrome?: boolean;
}

const {
  title,
  description,
  canonical,
  openGraph,
  twitter,
  noindex,
  nofollow,
  themeColor,
  showChrome = true,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const pathname = Astro.url.pathname;
const navLinks = [
  { href: `${base}/`, label: "Home", icon: "lucide:house" },
  { href: `${base}/blog`, label: "Blog", icon: "lucide:book-open" },
  { href: `${base}/linktree`, label: "Links", icon: "lucide:sparkles" },
];

const home = normalizeRoutePath(`${base}/`);
const currentPath = normalizeRoutePath(pathname);

const isActive = (href: string) => {
  const target = normalizeRoutePath(href);
  // The home link should only match the home route exactly, otherwise it
  // would match every page (since every path starts with the base).
  if (target === home) return currentPath === home;
  return currentPath === target || currentPath.startsWith(`${target}/`);
};
---

<!doctype html>
<html lang="en">
  <Head
    {title}
    {description}
    {canonical}
    {openGraph}
    {twitter}
    {noindex}
    {nofollow}
    {themeColor}
  >
    <ClientRouter />
    <slot name="head" />
  </Head>
  <body class="bg-background text-foreground min-h-screen flex flex-col">
    {showChrome && <CustomCursor />}
    {showChrome && <ThreeBackground />}
    {
      showChrome && (
        <header class="sticky top-0 z-50 border-b border-border/70 bg-background/80 shadow-sm shadow-primary/10 backdrop-blur-xl">
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-linear-to-r from-transparent via-primary/55 via-45% to-accent/45" />
          <nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
            <a
              href={`${base}/`}
              class="group flex min-w-0 items-center gap-3 rounded-md border border-border/80 bg-card/80 px-3 py-2 text-sm font-semibold shadow-sm transition-all hover:border-primary/50 hover:bg-card"
            >
              <span class="flex size-8 shrink-0 items-center justify-center rounded-md bg-primary text-primary-foreground shadow-lg shadow-primary/25 transition-transform group-hover:rotate-3 group-hover:scale-105">
                <Icon name="lucide:zap" width="17" height="17" />
              </span>
              <span class="hidden tracking-tight sm:block">ShadowNine.dev</span>
            </a>
            <div class="flex max-w-full items-center gap-1 rounded-lg border border-border/80 bg-card/70 p-1 shadow-sm">
              {navLinks.map(({ href, label, icon }) => (
                <a
                  href={href}
                  class:list={[
                    "group relative inline-flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium transition-all",
                    isActive(href)
                      ? "bg-primary text-primary-foreground shadow-sm shadow-primary/20"
                      : "text-muted-foreground hover:bg-accent hover:text-foreground",
                  ]}
                  aria-current={isActive(href) ? "page" : undefined}
                >
                  <Icon
                    name={icon}
                    width="16"
                    height="16"
                    class:list={[
                      "shrink-0 transition-transform",
                      isActive(href)
                        ? ""
                        : "group-hover:-translate-y-0.5 group-hover:scale-105",
                    ]}
                  />
                  <span class="hidden sm:inline">{label}</span>
                  <span class="sr-only sm:hidden">{label}</span>
                  {isActive(href) && (
                    <span class="absolute inset-x-3 -bottom-1 h-px rounded-full bg-primary-foreground/60" />
                  )}
                </a>
              ))}
            </div>
          </nav>
        </header>
      )
    }
    <main class="flex-1">
      <slot />
    </main>
    {showChrome && <Footer />}
  </body>
</html>
