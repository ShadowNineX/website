---
import "../styles/global.css";
import Head from "../components/Head.astro";
import { ClientRouter } from "astro:transitions";
import type { Props as SEOProps } from "astro-seo";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  openGraph?: SEOProps["openGraph"];
  twitter?: SEOProps["twitter"];
  noindex?: boolean;
  nofollow?: boolean;
}

const { title, description, canonical, openGraph, twitter, noindex, nofollow } =
  Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const pathname = Astro.url.pathname;
const navLinks = [
  { href: `${base}/`, label: "Home" },
  { href: `${base}/blog`, label: "Blog" },
  { href: `${base}/linktree`, label: "Links" },
];

const normalize = (path: string) => path.replace(/\/+$/, "") || "/";
const home = normalize(`${base}/`);
const currentPath = normalize(pathname);

const isActive = (href: string) => {
  const target = normalize(href);
  // The home link should only match the home route exactly, otherwise it
  // would match every page (since every path starts with the base).
  if (target === home) return currentPath === home;
  return currentPath === target || currentPath.startsWith(`${target}/`);
};
---

<!doctype html>
<html lang="en">
  <Head
    {title}
    {description}
    {canonical}
    {openGraph}
    {twitter}
    {noindex}
    {nofollow}
  >
    <ClientRouter />
    <slot name="head" />
  </Head>
  <body class="bg-background text-foreground min-h-screen flex flex-col">
    <header
      class="border-b border-border sticky top-0 z-50 bg-background/80 backdrop-blur-sm"
    >
      <nav
        class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <a href={`${base}/`} class="font-semibold text-sm">ShadowNine</a>
        <div class="flex gap-6 text-sm text-muted-foreground">
          {
            navLinks.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  "transition-colors",
                  isActive(href)
                    ? "text-foreground font-medium"
                    : "hover:text-foreground",
                ]}
              >
                {label}
              </a>
            ))
          }
        </div>
      </nav>
    </header>
    <main class="flex-1">
      <slot />
    </main>
  </body>
</html>
